<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SCLogReader.ViewModels"
        xmlns:m="using:SCLogReader.Models"
        xmlns:conv="using:SCLogReader.Converters"
        x:Class="SCLogReader.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="1040" Height="720"
        MinWidth="820" MinHeight="520"
        Background="#0D1117"
        Icon="/SCLogReader.ico"
        Title="SC Log Reader">

  <Window.Resources>
    <conv:AmountToBrushConverter x:Key="AmountBrush" />
    <conv:KindToBrushConverter x:Key="KindBrush" />
    <conv:FilterActiveConverter x:Key="FilterBg" />
  </Window.Resources>

  <DockPanel Margin="20">

    <!-- Kopfzeile -->
    <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" Margin="0,0,0,16">
      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
        <Border Background="#1F6FEB" CornerRadius="9" Width="36" Height="36">
          <TextBlock Text="✦" Foreground="White" FontSize="20"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <StackPanel VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="SC Log Reader" Foreground="#F0F6FC" FontSize="18" FontWeight="Bold" />
            <Button Background="#21262D" CornerRadius="6" Padding="7,2" BorderThickness="0"
                    VerticalAlignment="Center" Cursor="Hand"
                    Command="{Binding OpenChangelogCommand}"
                    ToolTip.Tip="Changelog / Releases öffnen">
              <TextBlock Text="{Binding VersionText}" Foreground="#8B949E" FontSize="11" FontWeight="SemiBold" />
            </Button>
          </StackPanel>
          <TextBlock Text="{Binding MetaSummary}" Foreground="#8B949E" FontSize="11" />
        </StackPanel>
      </StackPanel>

      <TextBox Grid.Column="1" Classes="path" Margin="20,0,10,0"
               VerticalAlignment="Center" Text="{Binding LogPath}" Watermark="Pfad zur Game.log" />
      <Button Grid.Column="2" Classes="ghost" Margin="0,0,8,0" VerticalAlignment="Center"
              Command="{Binding BrowseCommand}" Content="📁  Durchsuchen"
              ToolTip.Tip="Game.log manuell wählen (andere Platte / Pfad)" />
      <Button Grid.Column="3" Classes="ghost" Margin="0,0,8,0" VerticalAlignment="Center"
              Command="{Binding DetectCommand}" Content="Auto"
              ToolTip.Tip="Game.log automatisch finden (alle Laufwerke, LIVE/PTU/…)" />
      <Button Grid.Column="4" Classes="accent" MinWidth="92" VerticalAlignment="Center"
              HorizontalContentAlignment="Center"
              Command="{Binding ToggleCommand}" Content="{Binding ToggleText}" />
      <Button Grid.Column="5" Classes="accent" Margin="8,0,0,0" VerticalAlignment="Center"
              Background="#238636" IsVisible="{Binding UpdateAvailable}"
              Command="{Binding UpdateCommand}" Content="{Binding UpdateText}"
              ToolTip.Tip="Neue Version herunterladen und installieren" />
    </Grid>

    <!-- Session-Auswahl -->
    <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,12">
      <TextBlock Grid.Column="0" Text="Session" Foreground="#8B949E" FontWeight="SemiBold"
                 VerticalAlignment="Center" Margin="0,0,10,0" />
      <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                ItemsSource="{Binding Sessions}" SelectedItem="{Binding SelectedSession}" />
      <TextBlock Grid.Column="2" Text="{Binding SessionSpanText}" Foreground="#22D3EE"
                 FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,0,0" />
    </Grid>

    <!-- Karten -->
    <Grid DockPanel.Dock="Top" ColumnDefinitions="2*,*,2*,*" Margin="0,0,0,8">
      <Border Grid.Column="0" Classes="card" Margin="0,0,6,0">
        <StackPanel>
          <TextBlock Classes="label" Text="◉  STANDORT" />
          <TextBlock Classes="value" Text="{Binding CurrentLocation}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="1" Classes="card" Margin="6,0,6,0">
        <StackPanel>
          <TextBlock Classes="label" Text="✈  SCHIFF" />
          <TextBlock Classes="value" Text="{Binding CurrentShip}" />
          <TextBlock Text="{Binding FleetText}" Foreground="#8B949E" FontSize="12" Margin="0,2,0,0"
                     ToolTip.Tip="{Binding ShipsSeenText}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="2" Classes="card" Margin="6,0,6,0">
        <StackPanel>
          <TextBlock Classes="label" Text="◆  KONTOSTAND (echt)" />
          <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
            <TextBox Width="120" Padding="8,5" CornerRadius="6" Background="#0D1117" BorderBrush="#30363D"
                     FontFamily="Cascadia Code, Consolas, monospace" FontWeight="Bold" FontSize="14"
                     Text="{Binding ManualBalance}" Watermark="aUEC"
                     ToolTip.Tip="Echten aUEC-Kontostand eintragen, dann ✓ Setzen" />
            <Button Classes="accent" Padding="10,5" VerticalAlignment="Stretch"
                    Command="{Binding SetBalanceCommand}" Content="✓ Setzen"
                    ToolTip.Tip="Speichern und Saldo neu berechnen" />
            <TextBlock Text="✓ Gespeichert" Foreground="#3FB950" FontWeight="Bold" FontSize="12"
                       VerticalAlignment="Center" IsVisible="{Binding BalanceSaved}" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,6,0,0">
            <TextBlock Text="Erwartet:" Foreground="#8B949E" FontSize="13" VerticalAlignment="Center" />
            <TextBlock Text="{Binding ExpectedText}" Foreground="#F0F6FC" FontSize="15" FontWeight="Bold" />
          </StackPanel>
          <TextBlock Text="{Binding NetBalanceText}" FontSize="11" Margin="0,3,0,0"
                     Foreground="{Binding NetSign, Converter={StaticResource AmountBrush}}" />
          <TextBlock Text="{Binding TradeText}" Foreground="#22D3EE" FontSize="11" Margin="0,2,0,0" />
        </StackPanel>
      </Border>
      <Border Grid.Column="3" Classes="card" Margin="6,0,0,0">
        <StackPanel>
          <TextBlock Classes="label" Text="▣  LAGER" />
          <TextBlock Classes="value" Text="{Binding LastInventory}" FontSize="14" />
        </StackPanel>
      </Border>
    </Grid>

    <!-- Aktionsleiste -->
    <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto" Margin="0,8,0,12">
      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
        <Button Classes="ghost" Command="{Binding ExportCsvCommand}" Content="⬓  CSV" />
        <Button Classes="ghost" Command="{Binding ExportJsonCommand}" Content="⬓  JSON" />
      </StackPanel>
      <TextBlock Grid.Column="2" Text="{Binding Status}" Foreground="#8B949E"
                 FontSize="12" VerticalAlignment="Center" />
    </Grid>

    <!-- Tabs: Ereignisse + Geld-Stats -->
    <TabControl Padding="0">
    <TabItem Header="📜  Ereignisse" FontSize="13">
    <DockPanel Margin="0,8,0,0">

    <!-- Filter-Chips -->
    <ScrollViewer DockPanel.Dock="Top" HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Disabled" Margin="0,0,0,10">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Classes="chip" Content="Alle" Command="{Binding SetFilterCommand}" CommandParameter="Alle"
                Background="{Binding ActiveFilter, Converter={StaticResource FilterBg}, ConverterParameter=Alle}" />
        <Button Classes="chip" Content="💰 Geld" Command="{Binding SetFilterCommand}" CommandParameter="Geld"
                Background="{Binding ActiveFilter, Converter={StaticResource FilterBg}, ConverterParameter=Geld}" />
        <Button Classes="chip" Content="📋 Aufträge" Command="{Binding SetFilterCommand}" CommandParameter="Aufträge"
                Background="{Binding ActiveFilter, Converter={StaticResource FilterBg}, ConverterParameter=Aufträge}" />
        <Button Classes="chip" Content="⬡ Baupläne" Command="{Binding SetFilterCommand}" CommandParameter="Baupläne"
                Background="{Binding ActiveFilter, Converter={StaticResource FilterBg}, ConverterParameter=Baupläne}" />
        <Button Classes="chip" Content="✈ Schiffe" Command="{Binding SetFilterCommand}" CommandParameter="Schiffe"
                Background="{Binding ActiveFilter, Converter={StaticResource FilterBg}, ConverterParameter=Schiffe}" />
        <Button Classes="chip" Content="◉ Orte" Command="{Binding SetFilterCommand}" CommandParameter="Orte"
                Background="{Binding ActiveFilter, Converter={StaticResource FilterBg}, ConverterParameter=Orte}" />
        <Button Classes="chip" Content="♟ Crew" Command="{Binding SetFilterCommand}" CommandParameter="Crew"
                Background="{Binding ActiveFilter, Converter={StaticResource FilterBg}, ConverterParameter=Crew}" />
        <Button Classes="chip" Content="◈ Loot" Command="{Binding SetFilterCommand}" CommandParameter="Loot"
                Background="{Binding ActiveFilter, Converter={StaticResource FilterBg}, ConverterParameter=Loot}" />
        <Button Classes="chip" Content="⋯ Sonst" Command="{Binding SetFilterCommand}" CommandParameter="Sonst"
                Background="{Binding ActiveFilter, Converter={StaticResource FilterBg}, ConverterParameter=Sonst}" />
      </StackPanel>
    </ScrollViewer>

    <!-- Event-Tabelle -->
    <Border Classes="card" Padding="0">
      <DataGrid ItemsSource="{Binding EventsView}" IsReadOnly="True"
                SelectedItem="{Binding SelectedEntry}" DoubleTapped="OnGridDoubleTapped"
                CanUserResizeColumns="True" CanUserSortColumns="True" HeadersVisibility="Column">
        <DataGrid.ContextMenu>
          <ContextMenu>
            <MenuItem Header="🔎  Online nachschlagen" Command="{Binding LookupCommand}" />
          </ContextMenu>
        </DataGrid.ContextMenu>
        <DataGrid.Columns>
          <DataGridTemplateColumn Header="ZEIT" Width="165" SortMemberPath="Time">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="m:LogEntry">
                <TextBlock Text="{Binding TimeText}" Margin="12,0,0,0" VerticalAlignment="Center"
                           FontFamily="Cascadia Code, Consolas, monospace" FontSize="12" Foreground="#8B949E" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="TYP" Width="150" SortMemberPath="KindText">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="m:LogEntry">
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="12,0,0,0" VerticalAlignment="Center">
                  <TextBlock Text="{Binding Icon}" FontSize="13"
                             Foreground="{Binding Kind, Converter={StaticResource KindBrush}}" />
                  <TextBlock Text="{Binding KindText}" Foreground="#C9D1D9" />
                </StackPanel>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="BETRAG" Width="130" SortMemberPath="Amount">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="m:LogEntry">
                <TextBlock Text="{Binding AmountText}" Margin="0,0,14,0"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           FontFamily="Cascadia Code, Consolas, monospace" FontWeight="SemiBold"
                           Foreground="{Binding Amount, Converter={StaticResource AmountBrush}}" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="SALDO" Width="120" SortMemberPath="BalanceAfter">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="m:LogEntry">
                <TextBlock Text="{Binding BalanceAfterText}" Margin="0,0,14,0"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           FontFamily="Cascadia Code, Consolas, monospace" Foreground="#8B949E" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="DETAIL" Width="*" SortMemberPath="Detail">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="m:LogEntry">
                <TextBlock Text="{Binding Detail}" Margin="2,0,8,0" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" Foreground="{Binding StatusBrush}" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    </DockPanel>
    </TabItem>

    <TabItem Header="💰  Geld-Stats" FontSize="13">
      <ScrollViewer Margin="0,10,0,0" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="14">

          <!-- Hinweis: nicht geloggte Auftragsbelohnungen -->
          <Border Background="#1F3A2A14" BorderBrush="#FBBF24" BorderThickness="1"
                  CornerRadius="8" Padding="12,9" IsVisible="{Binding HasMissions}">
            <TextBlock Text="{Binding MissionsText}" Foreground="#FBBF24" FontSize="12" TextWrapping="Wrap" />
          </Border>

          <!-- Übersicht -->
          <Grid ColumnDefinitions="*,*,*">
            <Border Grid.Column="0" Classes="card" Margin="0,0,6,0">
              <StackPanel>
                <TextBlock Classes="label" Text="▼  EINNAHMEN" />
                <TextBlock Classes="value" Text="{Binding IncomeTotalText}" Foreground="#4ADE80" />
              </StackPanel>
            </Border>
            <Border Grid.Column="1" Classes="card" Margin="6,0,6,0">
              <StackPanel>
                <TextBlock Classes="label" Text="▲  AUSGABEN" />
                <TextBlock Classes="value" Text="{Binding SpendTotalText}" Foreground="#F87171" />
              </StackPanel>
            </Border>
            <Border Grid.Column="2" Classes="card" Margin="6,0,0,0">
              <StackPanel>
                <TextBlock Classes="label" Text="◆  NETTO (Log)" />
                <TextBlock Classes="value" Text="{Binding NetBalanceText}"
                           Foreground="{Binding NetSign, Converter={StaticResource AmountBrush}}" />
              </StackPanel>
            </Border>
          </Grid>

          <!-- Einnahmen-Aufschlüsselung -->
          <Border Classes="card">
            <StackPanel>
              <TextBlock Classes="label" Text="EINNAHMEN NACH QUELLE" Margin="0,0,0,8" />
              <ItemsControl ItemsSource="{Binding IncomeStats}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="m:StatItem">
                    <Grid ColumnDefinitions="150,290,Auto" Margin="0,3">
                      <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="#C9D1D9" VerticalAlignment="Center" />
                      <Border Grid.Column="1" Height="16" CornerRadius="4" HorizontalAlignment="Left"
                              Width="{Binding BarWidth}" Background="{Binding Color}" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="2" Text="{Binding ValueText}" Foreground="#F0F6FC"
                                 FontFamily="Cascadia Code, Consolas, monospace" FontSize="12"
                                 Margin="10,0,0,0" VerticalAlignment="Center" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- Ausgaben-Aufschlüsselung -->
          <Border Classes="card">
            <StackPanel>
              <TextBlock Classes="label" Text="AUSGABEN NACH ART" Margin="0,0,0,8" />
              <ItemsControl ItemsSource="{Binding SpendStats}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="m:StatItem">
                    <Grid ColumnDefinitions="150,290,Auto" Margin="0,3">
                      <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="#C9D1D9" VerticalAlignment="Center" />
                      <Border Grid.Column="1" Height="16" CornerRadius="4" HorizontalAlignment="Left"
                              Width="{Binding BarWidth}" Background="{Binding Color}" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="2" Text="{Binding ValueText}" Foreground="#F0F6FC"
                                 FontFamily="Cascadia Code, Consolas, monospace" FontSize="12"
                                 Margin="10,0,0,0" VerticalAlignment="Center" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- Handel je Ware -->
          <Border Classes="card" IsVisible="{Binding HasTrades}">
            <StackPanel>
              <TextBlock Classes="label" Text="HANDEL JE WARE (SCU · Ø Preis/SCU)" Margin="0,0,0,8" />
              <ItemsControl ItemsSource="{Binding CommodityTrades}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="m:StatItem">
                    <Grid ColumnDefinitions="150,*,Auto" Margin="0,4">
                      <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding Label}" Foreground="#F0F6FC" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Sub}" Foreground="#8B949E" FontSize="11" />
                      </StackPanel>
                      <Border Grid.Column="1" Height="16" CornerRadius="4" HorizontalAlignment="Left"
                              Width="{Binding BarWidth}" Background="{Binding Color}" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="2" Text="{Binding ValueText}" Foreground="#F0F6FC"
                                 FontFamily="Cascadia Code, Consolas, monospace" FontSize="12"
                                 Margin="10,0,0,0" VerticalAlignment="Center" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- Größte Einzel-Posten -->
          <Border Classes="card">
            <StackPanel>
              <TextBlock Classes="label" Text="GRÖSSTE EINZEL-POSTEN" Margin="0,0,0,8" />
              <ItemsControl ItemsSource="{Binding TopTransactions}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="m:StatItem">
                    <Grid ColumnDefinitions="100,*,Auto" Margin="0,3">
                      <TextBlock Grid.Column="0" Text="{Binding WhenText}" Foreground="#8B949E"
                                 FontFamily="Cascadia Code, Consolas, monospace" FontSize="11" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="1" Text="{Binding Label}" Foreground="#C9D1D9"
                                 TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="0,0,12,0" />
                      <TextBlock Grid.Column="2" Text="{Binding ValueText}"
                                 Foreground="{Binding Color}" FontWeight="SemiBold"
                                 FontFamily="Cascadia Code, Consolas, monospace" FontSize="12" VerticalAlignment="Center" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- Letzte Geld-Bewegungen (neueste zuerst) -->
          <Border Classes="card">
            <StackPanel>
              <TextBlock Classes="label" Text="LETZTE GELD-BEWEGUNGEN" Margin="0,0,0,8" />
              <ItemsControl ItemsSource="{Binding RecentMoney}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="m:StatItem">
                    <Grid ColumnDefinitions="100,*,Auto" Margin="0,3">
                      <TextBlock Grid.Column="0" Text="{Binding WhenText}" Foreground="#8B949E"
                                 FontFamily="Cascadia Code, Consolas, monospace" FontSize="11" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="1" Text="{Binding Label}" Foreground="#C9D1D9"
                                 TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="0,0,12,0" />
                      <TextBlock Grid.Column="2" Text="{Binding ValueText}"
                                 Foreground="{Binding Color}" FontWeight="SemiBold"
                                 FontFamily="Cascadia Code, Consolas, monospace" FontSize="12" VerticalAlignment="Center" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>
    </TabItem>
    </TabControl>

  </DockPanel>
</Window>
